SCAR_DATABASE_URL=postgresql+psycopg://USER:PASS@db:5432/scar

SCAR_S3_BUCKET=scar-assets
SCAR_S3_ACCESS_KEY=FILL_IN
SCAR_S3_SECRET_KEY=FILL_IN
# internal endpoint for api to put/get, inside the docker compose network
SCAR_S3_INTERNAL_ENDPOINT=http://minio:9000
# must be reachable from clients
SCAR_S3_PUBLIC_ENDPOINT=http://localhost:9000
# required by SigV4 signing, even though MinIO is region-agnostic
SCAR_S3_REGION=us-east-1
SCAR_PRESIGN_TTL_SECONDS=3600

SCAR_ADMIN_API_KEYS=FILL_IN-key:OPERATOR_NAME